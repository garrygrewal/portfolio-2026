---
import Layout from './Layout.astro';
import Divider from '../components/Divider.astro';
import MetricsRow from '../components/MetricsRow.astro';

interface Metric {
  value: string;
  label: string;
}

interface MetadataItem {
  label: string;
  values: string[];
}

interface Props {
  title: string;
  description: string;
  heroImageSrc?: string;
  heroImageAlt: string;
  heroVideo?: { webm: string; mp4?: string };
  metadata: MetadataItem[];
  metrics?: Metric[];
}

const { title, description, heroImageSrc, heroImageAlt, heroVideo, metadata, metrics } = Astro.props;
---

<Layout title={`${title} - Garry Grewal`}>
  <!-- Title and Metadata Section -->
  <div class="case-study-intro">
    <h1 class="case-study-title">{title}</h1>
    <div class="case-study-intro-row">
      <p class="case-study-description">{description}</p>
      <div class="case-study-metadata">
        {metadata.map((item) => (
          <div class="case-study-metadata-item">
            <div class="case-study-metadata-label">{item.label}</div>
            <div class="case-study-metadata-values">
              {item.values.map((value) => (
                <span class="case-study-metadata-value">{value}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Hero Image or Video -->
  <div class="case-study-hero">
    {heroVideo ? (
      <video class="case-study-hero-image" autoplay muted loop playsinline aria-label={heroImageAlt}>
        <source src={heroVideo.webm} type="video/webm" />
        {heroVideo.mp4 && <source src={heroVideo.mp4} type="video/mp4" />}
      </video>
    ) : heroImageSrc ? (
      <img src={heroImageSrc} alt={heroImageAlt} class="case-study-hero-image" />
    ) : null}
  </div>

  <!-- Metrics Row -->
  {metrics && metrics.length > 0 && <MetricsRow metrics={metrics} />}

  <!-- Divider -->
  <Divider />

  <!-- Content Slot -->
  <div class="case-study-content">
    <slot />
  </div>
</Layout>
