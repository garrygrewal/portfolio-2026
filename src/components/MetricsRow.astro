---
interface Metric {
  value: string;
  label: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<div class="metrics-row">
  {metrics.map((metric) => (
    <div class="metric">
      <div class="metric-value">{metric.value}</div>
      <div class="metric-label">{metric.label}</div>
    </div>
  ))}
</div>
