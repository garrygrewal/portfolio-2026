---
import CaseStudyLayout from '../layouts/CaseStudyLayout.astro';
import Figure from '../components/Figure.astro';

const metadata = [
  { label: 'Platform', value: 'iOS' },
  { label: 'Roles', value: 'Lead Product Designer' },
  { label: 'Year', value: '2023' },
  { label: 'Tools', value: 'Figma, Sketch' }
];

const metrics = [
  { value: '##', label: 'Metric label one' },
  { value: '##', label: 'Metric label two' },
  { value: '##', label: 'Metric label three' }
];
---

<CaseStudyLayout
  title="Case Study Four"
  description="Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae consequatur vel illum qui dolorem eum fugiat quo voluptas nulla pariatur at vero eos et accusamus et iusto odio dignissimos."
  heroImageSrc="/placeholders/hero-1.svg"
  heroImageAlt="Case Study Four Hero"
  metadata={metadata}
  metrics={metrics}
>
  <!-- Two-column layout: small left, large right -->
  <div class="content-block-2col">
    <Figure
      src="/placeholders/image-left.svg"
      alt="Left aligned image"
      caption="Ducimus qui blanditiis praesentium voluptatum deleniti."
    />
    <Figure
      src="/placeholders/image-right.svg"
      alt="Right aligned larger image"
      caption="Atque corrupti quos dolores et quas molestias excepturi sint occaecati."
    />
  </div>

  <!-- Text block -->
  <div class="content-block-text">
    <p>Cupiditate non provident similique sunt in culpa qui officia deserunt mollitia animi id est laborum et dolorum fuga et harum quidem rerum facilis est et expedita distinctio nam libero tempore.</p>
  </div>

  <!-- Full width image -->
  <div class="content-block-full">
    <Figure
      src="/placeholders/image-full.svg"
      alt="Full width image"
      caption="Cum soluta nobis est eligendi optio cumque nihil impedit quo minus id quod maxime."
    />
  </div>

  <!-- Offset right image -->
  <div class="content-block-offset-right">
    <Figure
      src="/placeholders/image-small.svg"
      alt="Right offset image"
      caption="Placeat facere possimus omnis voluptas assumenda est."
    />
  </div>

  <!-- Text block -->
  <div class="content-block-text">
    <p>Omnis dolor repellendus temporibus autem quibusdam et aut officiis debitis aut rerum necessitatibus saepe eveniet ut et voluptates repudiandae sint et molestiae non recusandae itaque earum rerum hic tenetur.</p>
  </div>

  <!-- Large image -->
  <div class="content-block-full">
    <Figure
      src="/placeholders/hero-1.svg"
      alt="Large content image"
      caption="Sapiente delectus ut aut reiciendis voluptatibus maiores alias consequatur."
    />
  </div>

  <!-- Two-up images at bottom -->
  <div class="content-block-2up">
    <Figure
      src="/placeholders/square-1.svg"
      alt="Two-up image left"
      caption="Aut perferendis doloribus asperiores repellat vel qui eum iusto."
    />
    <Figure
      src="/placeholders/square-1.svg"
      alt="Two-up image right"
      caption="Odio dignissimos ducimus qui blanditiis praesentium voluptatum deleniti."
    />
  </div>
</CaseStudyLayout>
