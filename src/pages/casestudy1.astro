---
import CaseStudyLayout from '../layouts/CaseStudyLayout.astro';
import Figure from '../components/Figure.astro';

const metadata = [
  { label: 'Platform', value: 'iOS, Android' },
  { label: 'Roles', value: 'Product Design, UX Research' },
  { label: 'Year', value: '2024' },
  { label: 'Tools', value: 'Figma, Principle' }
];

const metrics = [
  { value: '##', label: 'Metric label one' },
  { value: '##', label: 'Metric label two' },
  { value: '##', label: 'Metric label three' }
];
---

<CaseStudyLayout
  title="Case Study One"
  description="Lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
  heroImageSrc="/placeholders/hero-1.svg"
  heroImageAlt="Case Study One Hero"
  metadata={metadata}
  metrics={metrics}
>
  <!-- Two-column layout: small left, large right -->
  <div class="content-block-2col">
    <Figure
      src="/placeholders/image-left.svg"
      alt="Left aligned image"
      caption="Lorem ipsum dolor amet consectetur adipiscing."
    />
    <Figure
      src="/placeholders/image-right.svg"
      alt="Right aligned larger image"
      caption="Consectetur adipiscing elit sed do eiusmod tempor incididunt labore dolore magna."
    />
  </div>

  <!-- Text block -->
  <div class="content-block-text">
    <p>Quis non ipsum commodo nostrud aliquip proident voluptate minim cupidatat paratur dolore consequat culpa incididunt lorem nulla enim adipisicing labore esse eiusmod magna exercitation.</p>
  </div>

  <!-- Full width image -->
  <div class="content-block-full">
    <Figure
      src="/placeholders/image-full.svg"
      alt="Full width image"
      caption="Sed do eiusmod tempor incididunt labore dolore magna aliqua."
    />
  </div>

  <!-- Offset right image -->
  <div class="content-block-offset-right">
    <Figure
      src="/placeholders/image-small.svg"
      alt="Right offset image"
      caption="Ut enim ad minim veniam quis nostrud."
    />
  </div>

  <!-- Text block -->
  <div class="content-block-text">
    <p>Lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua ut enim ad minim veniam quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
  </div>

  <!-- Large image -->
  <div class="content-block-full">
    <Figure
      src="/placeholders/hero-1.svg"
      alt="Large content image"
      caption="Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore."
    />
  </div>

  <!-- Two-up images at bottom -->
  <div class="content-block-2up">
    <Figure
      src="/placeholders/square-1.svg"
      alt="Two-up image left"
      caption="Excepteur sint occaecat cupidatat non proident."
    />
    <Figure
      src="/placeholders/square-1.svg"
      alt="Two-up image right"
      caption="Sunt in culpa qui officia deserunt mollit anim id est laborum."
    />
  </div>
</CaseStudyLayout>
